# 生产/发布环境配置（next build / next start 时加载）
NEXT_PUBLIC_API_BASE=https://api.linkwordx.xyz
# 浏览器端走同源 /proxy-api（见 next.config rewrites），避免 www 与 api 跨域；未设则仍直连 NEXT_PUBLIC_API_BASE
NEXT_PUBLIC_BROWSER_API_PREFIX=/proxy-api
# 可选：SSR 请求单独使用的 API 地址（如内网域名），未配置则用 NEXT_PUBLIC_API_BASE
# API_BASE_SERVER=http://api:9901
# 站点 URL，用于 SEO（sitemap、OG 等）
NEXT_PUBLIC_SITE_URL=https://linkwordx.xyz
